{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Assistant",
  "version": "0.1.0",
  "identifier": "com.leili.cc-assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CC Assistant",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "all": false,
      "readFile": true,
      "writeFile": true,
      "readDir": true,
      "copyFile": false,
      "createDir": true,
      "removeDir": false,
      "removeFile": false,
      "renameFile": false,
      "exists": true,
      "scope": {
        "allow": [
          "$HOME/.claude/**",
          "$APPDATA/claude/**",
          "$HOME/**/.claude/**"
        ]
      }
    }
  }
}
